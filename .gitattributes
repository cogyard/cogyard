# Files tracked in the private working repo but EXCLUDED from the public snapshot.
#
# `git archive` (the snapshot mechanism — see _tasks/050) honors `export-ignore`,
# so these are omitted from the published tree automatically. No manual deletion
# to forget. Add new private-but-tracked files here as they appear.

# Private maintainer infra. docs/DEVELOPMENT.md is the public replacement.
CLAUDE.md export-ignore

# Owner-internal A/B diff helper (developer tooling, not part of the product).
scripts/ab-api.sh export-ignore

# Maintainer publish/backup tooling (task 63) — NOT part of the public product, and
# the scanner + manifest even contain owner/other-project names as match patterns, so
# publishing them would itself be a leak. These stay private; the public snapshot is
# produced BY them, it does not contain them.
bin/publish-snapshot export-ignore
bin/backup-check export-ignore
scripts/secret-scan.sh export-ignore
scripts/install-git-hooks.sh export-ignore
scripts/githooks/pre-push export-ignore
scripts/githooks/pre-commit export-ignore
publish/public-manifest.txt export-ignore

# This machine's real deploy config (owner paths). Public repo has generic examples.
local/** export-ignore
local/ export-ignore

# First-person portal design LOG (personal quotes, planet clone names, "Ben"
# throughout). Kept in the private repo as a record; not public reference material.
docs/PORTAL-V2-DESIGN.md export-ignore

# Private owner notes (*.local.md — name ratings, deployment specifics, etc.). Tracked
# so they're in the private backup, export-ignore'd so they never reach public. This
# replaces the old `*.local.md` gitignore rule, which was silently dropping them from
# the backup entirely.
*.local.md export-ignore

# demo machinery (tasks 087/088) — private on main, never in the public snapshot
extras/demo-maker/** export-ignore
extras/demo-maker/ export-ignore
extras/demo-shadow/** export-ignore
extras/demo-shadow/ export-ignore

# GitHub Actions workflows of the PRIVATE repo (task 089's nightly demo refresh
# and any future automation) — repo infra, never part of the public snapshot.
.github/** export-ignore
.github/ export-ignore
