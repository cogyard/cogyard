node_modules/
frontend/node_modules/
frontend/dist/
frontend/.angular/
# generated at build by scripts/generate-version.mjs (version + commit, one source)
frontend/src/version.json
*.log
.DS_Store
.cache/
# NOTE: *.local.md (private owner notes) are NO LONGER gitignored. gitignore drops a
# file from EVERY commit — including the private backup — so those notes were going
# unsaved. They are now TRACKED + export-ignore'd (.gitattributes) instead: saved to
# the private backup, stripped from the public snapshot. gitignore is for regenerable
# junk only; anything you'd want back after a disk death must be tracked.
# task system: _tasks is a symlink to the shared store (tasks.mjs convert)
_tasks
frontend/public/assets/material-icons/
# worktree port management: written per-worktree by the SessionStart hook
.claude/launch.json
.env.worktree
