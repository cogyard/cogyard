{
  "name": "@cogyard/frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node ../scripts/generate-version.mjs && node scripts/copy-material-icons.mjs",
    "start": "ng serve --proxy-config proxy.conf.mjs",
    "prebuild": "node ../scripts/generate-version.mjs && node scripts/copy-material-icons.mjs",
    "build": "ng build",
    "postbuild": "node -e \"require('node:fs').writeFileSync('dist/.build-complete', String(Date.now()))\"",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "license": "MIT",
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/animations": "^21.2.16",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.5",
    "@primeuix/themes": "^1.1.0",
    "codemirror": "^6.0.2",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "primeng": "^21.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "vscode-material-icons": "^0.1.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
