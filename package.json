{
  "name": "cogyard",
  "version": "1.32.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "description": "from AI chats to shipped products: cogyard keeps track of multiple projects running at once — every task, worktree, and merge across every project in one place. Open source, agent-agnostic.",
  "keywords": [
    "ai-agents",
    "claude-code",
    "task-management",
    "git-worktree",
    "agent-coordination",
    "markdown-tasks",
    "cli",
    "portal"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cogyard/cogyard.git"
  },
  "homepage": "https://cogyard.com",
  "bugs": {
    "url": "https://github.com/cogyard/cogyard/issues"
  },
  "bin": {
    "cogyard": "cli/cogyard.mjs"
  },
  "files": [
    "cli/",
    "core/",
    "server/",
    "hooks/",
    "drivers/",
    "frontend/dist/frontend/browser"
  ],
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "api": "node server/index.mjs",
    "dev": "bash scripts/dev.sh",
    "test": "node --test",
    "test:clean-machine": "bash test/clean-machine.sh",
    "lint:leaks": "bash scripts/leak-scan.sh",
    "prepack": "npm run build",
    "frontend": "npm start -w frontend",
    "build": "npm run build -w frontend",
    "start": "node cli/cogyard.mjs serve",
    "serve": "node cli/cogyard.mjs serve",
    "desktop": "bin/build-desktop",
    "desktop:build": "bin/build-desktop --no-open",
    "desktop:dev": "npm --prefix extras/desktop install && npm --prefix extras/desktop run dev"
  },
  "overrides": {
    "rxjs": "7.8.2"
  },
  "dependencies": {
    "pino": "^10.3.1"
  }
}
